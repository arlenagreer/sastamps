{
  "name": "sastamps",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "npm run serve",
    "serve": "http-server . -p 3000",
    "build": "node scripts/build.js",
    "build:css": "postcss css/styles.css -o dist/css/styles.min.css",
    "build:js": "node esbuild.config.js",
    "build:js:legacy": "esbuild js/script.js --bundle --minify --outfile=dist/js/script.min.js",
    "analyze:bundle": "node esbuild.config.js && cat dist/bundle-analysis.json",
    "download:newsletters": "node scripts/download-newsletters.mjs",
    "watch": "npm-run-all --parallel watch:*",
    "watch:css": "postcss css/styles.css -o dist/css/styles.min.css --watch",
    "watch:js": "esbuild js/script.js --bundle --watch --outfile=dist/js/script.min.js",
    "analyze": "node scripts/analyze-image-savings.js",
    "monitor": "npm run serve",
    "build:search": "node scripts/build-search-index.js",
    "build:search:embed": "node scripts/build-search-embedded.js",
    "test": "npm run test:html && npm run test:links && npm run test:js && npm run test:css && npm run test:md",
    "test:html": "html-validate '*.html' '!test-*.html' --config .htmlvalidate.json",
    "test:links": "echo 'Run npm run test:links:server in a separate terminal first' && linkinator http://localhost:3000 --recurse --skip 'external'",
    "test:links:server": "echo 'Starting server for link checking...' && npm run serve",
    "test:js": "eslint js/**/*.js",
    "test:css": "stylelint 'css/**/*.css' --config .stylelintrc.json",
    "test:md": "markdownlint '**/*.md' --ignore node_modules --ignore browser-tools-test --ignore 'dist/**' --ignore '*.bak' --config .markdownlintrc.json",
    "test:a11y": "pa11y-ci --config .pa11yrc.json",
    "audit": "npm run audit:lighthouse && npm run audit:security",
    "audit:lighthouse": "lighthouse http://localhost:3000 --output html --output-path ./reports/lighthouse.html --view",
    "audit:security": "npm audit",
    "test:quick": "npm run test:html && npm run test:js && npm run test:css",
    "validate:data": "node scripts/validate-data.js",
    "pretest": "mkdir -p reports"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arlenagreer/arlenagreer.github.io.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/arlenagreer/arlenagreer.github.io/issues"
  },
  "homepage": "https://github.com/arlenagreer/arlenagreer.github.io#readme",
  "description": "",
  "dependencies": {
    "@types/node": "^26.1.1",
    "lunr": "^2.3.9",
    "nanoid": "^3.3.15",
    "node-fetch": "^3.3.2",
    "sharp": "^0.35.3",
    "vanilla-calendar-pro": "^3.1.0",
    "yargs": "^17.7.3"
  },
  "devDependencies": {
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "autoprefixer": "^10.5.2",
    "cssnano": "^8.0.2",
    "esbuild": "^0.28.1",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "html-validate": "^11.5.6",
    "http-server": "^14.1.1",
    "lighthouse": "^13.4.0",
    "linkinator": "^7.6.1",
    "markdownlint-cli": "^0.49.0",
    "npm-run-all": "^4.1.5",
    "pa11y": "^9.1.1",
    "postcss": "^8.5.18",
    "postcss-cli": "^11.0.0",
    "stylelint": "^17.14.0",
    "stylelint-config-standard": "^40.0.0"
  },
  "browserslist": [
    ">0.2%",
    "not dead",
    "not op_mini all"
  ],
  "overrides": {
    "glob": "^11.1.0"
  }
}
